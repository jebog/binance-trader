# Copy this file to .env and fill in your values before running.

# ── Binance API credentials ──────────────────────────────────
# Create a Binance API key with Spot trading enabled, IP whitelist recommended.
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# ── Telegram ──────────────────────────────────────────────────
# Create a bot via @BotFather, start a chat, get your chat_id via @userinfobot.
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Webhook (optional — leave empty to disable) ───────────────
WEBHOOK_URL=

# ── Cron mode (launchd) ──────────────────────────────────────
# Set to "true" to enable the launchd cron job (every 30 min).
# The TUI has full feature parity — cron is optional.
CRON_ENABLED=false

# ── ETH Accumulation (DCA + Staking) ─────────────────────────
# Long-term ETH accumulation targeting 1 ETH, runs alongside scanner.
# Set DCA_ENABLED=true to start weekly buys from USDC balance.
DCA_ENABLED=false
DCA_TARGET_QTY=1.0
DCA_AMOUNT_USDC=40.0
DCA_DAY_OF_WEEK=3        # 0=Mon, 3=Thu, 6=Sun
DCA_HOUR=10              # 0-23 local time
DCA_RESERVE_MULT=10      # reserve N weeks upfront (untouchable by scanner)
DCA_MIN_SCANNER_USDC=200 # scanner won't be starved below this floor

# ── ETH Staking (Binance Flexible) ───────────────────────────
# Auto-stake accumulated ETH to earn ~2.5-3% APY.
# Requires you to have stakable ETH on Binance.
STAKING_ENABLED=false
STAKING_AUTO_STAKE=true
